<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Unity Trust — Dashboard</title>

<script src="https://cdn.tailwindcss.com"></script>

<script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        navy:'#0b1834',
        mid:'#071a38',
        deep:'#04122a',
        accentA:'#00BFFF',
        accentB:'#0077FF'
      }
    }
  }
}
</script>

<style>
.glass {
  background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
  backdrop-filter: blur(10px);
}
.copy-btn {
  cursor: pointer;
}
</style>
</head>

<body class="bg-gradient-to-b from-navy via-mid to-deep text-slate-100 min-h-screen flex flex-col">

<!-- HEADER -->
<header class="flex justify-between items-center px-6 py-4 border-b border-white/10">
  <h1 class="text-xl font-bold">Unity Trust</h1>
  <div class="flex items-center gap-3">
    <span class="text-sm">Account Name, <strong><%= name %></strong></span>
    <img src="/logo.jpeg" class="h-8 w-8 rounded-full">
  </div>
</header>

<!-- MAIN CONTENT -->
<main class="flex-1 p-6 space-y-8">

  <!-- ACCOUNT CARDS -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
    <div class="glass p-5 rounded-xl">
      <p class="text-xs text-slate-400">Available Balance</p>
      <h3 class="text-2xl font-bold">$<%= deposit.toFixed(2) %></h3>
    </div>
    <div class="glass p-5 rounded-xl">
      <p class="text-xs text-slate-400">Savings</p>
      <h3 class="text-2xl font-bold">$<%= profit.toFixed(2) %></h3>
    </div>
    <div class="glass p-5 rounded-xl">
      <p class="text-xs text-slate-400">Account</p>
      <h3 class="text-xl font-bold">Savings ••••942</h3>
    </div>
    <div class="glass p-5 rounded-xl">
      <p class="text-xs text-slate-400">Status</p>
      <h3 class="text-xl font-bold text-emerald-400">Active</h3>
    </div>
  </div>

  <!-- FORMS -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- Deposit Form -->
    <form class="xl:col-span-2 glass p-6 rounded-xl space-y-4">
      <h3 class="font-semibold text-lg">Deposit</h3>
      <input type="number" placeholder="Amount (USD)" class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />

      <!-- Crypto Addresses -->
      <div class="space-y-2">
        <label class="text-sm text-slate-400">Select Crypto & Copy Address</label>
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <div class="flex-1 glass p-3 rounded-md flex justify-between items-center">
            <span>BTC</span>
            <span id="btc-address" class="copy-btn text-xs text-accentA font-mono">bc1q4md3cgfq43zzje39g6vjwpfw8nzlrnupe2tmnt</span>
          </div>
          <div class="flex-1 glass p-3 rounded-md flex justify-between items-center">
            <span>ETH</span>
            <span id="eth-address" class="copy-btn text-xs text-accentA font-mono">0x2d436d2813b05E49BfdC62Dc28549ca034e80487</span>
          </div>
          <div class="flex-1 glass p-3 rounded-md flex justify-between items-center">
            <span>USDT</span>
            <span id="bnb-address" class="copy-btn text-xs text-accentA font-mono">0x2d436d2813b05E49BfdC62Dc28549ca034e80487</span>
          </div>
          <div class="flex-1 glass p-3 rounded-md flex justify-between items-center">
            <span>SOL</span>
            <span id="sol-address" class="copy-btn text-xs text-accentA font-mono">GKKQ7bQC8HRzTyDeQrgjHjJ925bJnkrMSa9xqJjzf6sk</span>
          </div>
        </div>
      </div>

      <button type="button" onclick="alert('Deposit submitted')" class="w-full bg-gradient-to-r from-accentA to-accentB text-black py-2 rounded font-bold">Submit</button>
      <p class="text-xs text-yellow-400">Pending admin approval</p>
    </form>

    <!-- Transfer Form -->
    <form class="glass p-6 rounded-xl space-y-4">
      <h3 class="font-semibold text-lg">Transfer</h3>
      <input type="text" placeholder="Bank" class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />
      <input type="number" placeholder="Amount (USD)" class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />
      <button type="button" onclick="alert('Complete 2 transactions first')" class="w-full bg-gradient-to-r from-accentA to-accentB text-black py-2 rounded font-bold">Transfer</button>
    </form>

  </div>
<!-- Withdrawal Form -->
<form class="glass p-6 rounded-xl space-y-4">
  <h3 class="font-semibold text-lg">Withdraw</h3>
  
  <input type="text" placeholder="Wallet / Bank Details"
    class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />

  <input type="number" placeholder="Amount (USD)"
    class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />

  <button type="button" onclick="handleWithdraw()"
    class="w-full bg-gradient-to-r from-accentA to-accentB text-black py-2 rounded font-bold">
    Withdraw
  </button>

  <p id="withdraw-message" class="text-sm text-red-400 hidden">
    Perform 2 more transactions before you'll be able to withdraw.
  </p>
</form>
     <div class="glass rounded-2xl overflow-hidden">
        <div class="p-6 border-b border-white/10 flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">Savings Statement</h3>
            <p class="text-sm text-slate-400 mt-1">Savings Account Statement #001185707158</p>
          </div>
          <button class="w-12 h-12 rounded-full bg-gradient-to-br from-accentA/30 to-accentB/30 flex items-center justify-center hover:from-accentA/50 hover:to-accentB/50 transition">
            <span class="text-2xl">▶️</span>
          </button>
        </div>

        <!-- Transaction table -->
       <div class="p-6">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <div class="text-sm text-slate-300">
              Show 
              <select class="bg-slate-800 border border-white/20 rounded px-2 py-1 text-sm">
                <option>10</option>
                <option>25</option>
                <option>50</option>
              </select> 
              entries
            </div>
            <div>
              <input type="text" placeholder="Search..." class="bg-slate-800/70 border border-white/10 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-accentA/50 w-48" />
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="text-slate-400 border-b border-white/10">
                <tr>
                  <th class="py-4 text-left font-normal">Date</th>
                  <th class="py-4 text-left font-normal">Type</th>
                  <th class="py-4 text-left font-normal">Amount</th>
                  <th class="py-4 w-10"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <!-- Transactions rows (10 sample rows) -->
                <script>
                  const transactions = [
                    {date:"28th January, 2026", type:"Credit", amount:"$12,450.00", desc:"Salary deposit - TechCorp Ltd", ref:"TRX-20260128-3194"},
                    {date:"25th January, 2026", type:"Debit", amount:"$3,875.60", desc:"Online purchase - Electronics store", ref:"TRX-20260125-0821"},
                    {date:"19th January, 2026", type:"Credit", amount:"$45,000.00", desc:"Investment return - Portfolio #A472", ref:""},
                    {date:"15th January, 2026", type:"Debit", amount:"$1,920.00", desc:"Utility bill payment - Electricity", ref:""},
                    {date:"10th January, 2026", type:"Debit", amount:"$8,250.75", desc:"Transfer to family account", ref:""},
                    {date:"7th January, 2026", type:"Credit", amount:"$22,300.00", desc:"Freelance payment received", ref:""},
                    {date:"3rd January, 2026", type:"Debit", amount:"$4,180.00", desc:"Rent payment - January", ref:""},
                    {date:"30th December, 2025", type:"Credit", amount:"$18,750.00", desc:"Bonus payout", ref:""},
                    {date:"27th December, 2025", type:"Debit", amount:"$2,640.50", desc:"Christmas shopping - Various", ref:""},
                    {date:"20th December, 2025", type:"Credit", amount:"$9,875.00", desc:"Client payment - Project X", ref:""}
                  ];

                  for(const t of transactions){
                    document.write(`
                      <tr class="group hover:bg-white/5 transition">
                        <td class="py-4">${t.date}</td>
                        <td class="py-4 ${t.type==="Credit"?"text-emerald-400":"text-red-400"}">${t.type}</td>
                        <td class="py-4 font-medium">${t.amount}</td>
                        <td class="py-4">
                          <button onclick="this.closest('tr').nextElementSibling.classList.toggle('hidden'); this.querySelector('span').textContent = this.closest('tr').nextElementSibling.classList.contains('hidden') ? '+' : '−';"
                            class="w-8 h-8 rounded-full bg-blue-600/30 hover:bg-blue-600/50 flex items-center justify-center text-lg font-bold transition">
                            <span>+</span>
                          </button>
                        </td>
                      </tr>
                      <tr class="hidden bg-slate-900/40">
                        <td colspan="4" class="p-5 text-slate-300 text-sm">
                          <div class="space-y-2">
                            ${t.ref?`<p><strong>Reference:</strong> ${t.ref}</p>`:""}
                            <p><strong>Description:</strong> ${t.desc}</p>
                          </div>
                        </td>
                      </tr>
                    `)
                  }
                </script>
              </tbody>
            </table>
          </div>

  <!-- TRANSACTIONS -->
 
</main>


<footer class="text-center text-slate-400 py-6">©️ 2025 Unity Trust</footer>

<script>
// COPY ADDRESS FUNCTION
['btc','eth','bnb','sol'].forEach(id => {
  const el = document.getElementById(id+'-address');
  el.addEventListener('click', () => {
    navigator.clipboard.writeText(el.textContent).then(() => {
      alert(id.toUpperCase() + ' address copied!');
    });
  });
});

// WITHDRAW FUNCTION
function handleWithdraw() {
  const message = document.getElementById('withdraw-message');
  message.classList.remove('hidden');
}
// COPY ADDRESS FUNCTION
['btc','eth','bnb','sol'].forEach(id => {
  const el = document.getElementById(id+'-address');
  el.addEventListener('click', () => {
    navigator.clipboard.writeText(el.textContent).then(() => {
      alert(id.toUpperCase() + ' address copied!');
    });
  });
});
</script>
